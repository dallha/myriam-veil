  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState, useEffect } from \"react\";\nimport { CollectionId, Product, CartItem } from \"./types\";\nimport { PRODUCTS } from \"./data\";\nimport { X, ArrowRight, Heart, Sparkles, User, Info, HelpCircle } from \"lucide-react\";\n\nimport TopAppBar from \"./components/TopAppBar\";\nimport BottomNav from \"./components/BottomNav\";\nimport UniversalCart from \"./components/UniversalCart\";\nimport OrigineEntry from \"./components/OrigineEntry\";\nimport CollectionCouture from \"./components/CollectionCouture\";\nimport CollectionEcrin from \"./components/CollectionEcrin\";\nimport CollectionHeritage from \"./components/CollectionHeritage\";\n\nexport default function App() {\n  // Collection lines selection: \"origins\" (Default Entry split) | \"couture\" | \"ecrin\" | \"heritage\"\n  const [currentCollection, setCurrentCollection] = useState<CollectionId>(\"origins\");\n\n  // Shopping Cart items state (hydrating from localStorage if present)\n  const [cartItems, setCartItems] = useState<CartItem[]>(() => {\n    try {\n      const stored = localStorage.getItem(\"myriam_veil_cart\");\n      return stored ? JSON.parse(stored) : [];\n    } catch {\n      return [];\n    }\n  });\n\n  // UI state overlays\n  const [isCartOpen, setIsCartOpen] = useState(false);\n  const [isMenuOpen, setIsMenuOpen] = useState(false);\n\n  // Sync cart items to client-side localStorage\n  useEffect(() => {\n    localStorage.setItem(\"myriam_veil_cart\", JSON.stringify(cartItems));\n  }, [cartItems]);\n\n  // Compute total cart quantity items in checkout\n  const cartCount = cartItems.reduce((acc, item) => acc + item.quantity, 0);\n\n  // Cart operations\n  const handleAddToCart = (product: Product, selectedSize?: string) => {\n    setCartItems((prevItems) => {\n      // Find matching item by ID and optionally selected size\n      const existingIdx = prevItems.findIndex(\n        (item) => item.product.id === product.id && item.selectedSize === selectedSize\n      );\n\n      if (existingIdx > -1) {\n        const updated = [...prevItems];\n        updated[existingIdx].quantity += 1;\n        return updated;\n      } else {\n        return [...prevItems, { product, quantity: 1, selectedSize }];\n      }\n    });\n\n    // Momentary slight pop on basket to catch attention\n    setIsCartOpen(true);\n  };\n\n  const handleUpdateQuantity = (productId: string, quantity: number, selectedSize?: string) => {\n    if (quantity < 1) {\n      handleRemoveItem(productId, selectedSize);\n      return;\n    }\n\n    setCartItems((prevItems) =>\n      prevItems.map((item) =>\n        item.product.id === productId && item.selectedSize === selectedSize\n          ? { ...item, quantity }\n          : item\n      )\n    );\n  };\n\n  const handleRemoveItem = (productId: string, selectedSize?: string) => {\n    setCartItems((prevItems) =>\n      prevItems.filter(\n        (item) => !(item.product.id === productId && item.selectedSize === selectedSize)\n      )\n    );\n  };\n\n  const handleClearCart = () => {\n    setCartItems([]);\n  };\n\n  const selectCollectionLine = (lineId: CollectionId) => {\n    setCurrentCollection(lineId);\n    setIsMenuOpen(false);\n    window.scrollTo({ top: 0, behavior: \"smooth\" });\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#f8f7f6] text-[#050505] flex flex-col relative overflow-x-hidden font-sans select-none antialiased\">\n      {/* 1. BRAND GLOBAL HEADER */}\n      {currentCollection !== \"origins\" && (\n        <TopAppBar\n          currentCollection={currentCollection}\n          onSetCollection={selectCollectionLine}\n          cartCount={cartCount}\n          onToggleCart={() => setIsCartOpen(!isCartOpen)}\n          onOpenMenu={() => setIsMenuOpen(true)}\n        />\n      )}\n\n      {/* 2. ADAPTIVE LINE VIEWPORT ROUTING */}\n      <main className=\"flex-1 w-full\">\n        {currentCollection === \"origins\" && (\n          <OrigineEntry onSelectCollection={selectCollectionLine} />\n        )}\n\n        {currentCollection === \"couture\" && (\n          <CollectionCouture\n            products={PRODUCTS.filter((p) => p.collectionId === \"couture\")}\n            onAddToCart={handleAddToCart}\n          />\n        )}\n\n        {currentCollection === \"ecrin\" && (\n          <CollectionEcrin\n            products={PRODUCTS.filter((p) => p.collectionId === \"ecrin\")}\n            onAddToCart={handleAddToCart}\n          />\n        )}\n\n        {currentCollection === \"heritage\" && (\n          <CollectionHeritage\n            products={PRODUCTS.filter((p) => p.collectionId === \"heritage\")}\n            onAddToCart={handleAddToCart}\n          />\n        )}\n      </main>\n\n      {/* 3. UNIVERSAL FLOATING NAV PILL */}\n      <BottomNav\n        currentCollection={currentCollection}\n        onSetCollection={selectCollectionLine}\n        onToggleCart={() => setIsCartOpen(!isCartOpen)}\n        cartCount={cartCount}\n      />\n\n      {/* 4. HIGH FIDELITY CART DRAWER */}\n      <UniversalCart\n        isOpen={isCartOpen}\n        onClose={() => setIsCartOpen(false)}\n        cartItems={cartItems}\n        onUpdateQuantity={handleUpdateQuantity}\n        onRemoveItem={handleRemoveItem}\n        onClearCart={handleClearCart}\n      />\n\n      {/* 5. EDITORIAL SLIDE-OVER INDEX SELECTIONS DRAWER */}\n      {isMenuOpen && (\n        <div className=\"fixed inset-0 z-50 overflow-hidden font-sans\">\n          {/* Menu backdrop */}\n          <div\n            onClick={() => setIsMenuOpen(false)}\n            className=\"absolute inset-0 bg-[#050505]/35 backdrop-blur-md transition-opacity duration-300\"\n          />\n\n          {/* Sidebar Area Container */}\n          <div className=\"absolute inset-y-0 left-0 max-w-[400px] w-full bg-[#f8f7f6] shadow-2xl flex flex-col transform transition-transform duration-300 border-r border-[#050505]\">\n            <header className=\"px-6 py-6 border-b border-[#050505]/10 flex justify-between items-center bg-[#EBE9E4]/30\">\n              <span className=\"font-display font-bold tracking-[0.2em] text-[#050505] text-sm md:text-base\">\n                Maison Myriam Veil\n              </span>\n              <button\n                id=\"close-sidebar-menu-btn\"\n                onClick={() => setIsMenuOpen(false)}\n                className=\"text-[#050505] hover:text-[#E6A219] transition-colors p-1 cursor-pointer\"\n              >\n                <X className=\"w-6 h-6 stroke-[1.5]\" />\n              </button>\n            </header>\n\n            {/* List Links segment */}\n            <nav className=\"flex-1 px-8 py-10 flex flex-col justify-between\">\n              <div className=\"space-y-8\">\n                {/* L\'Origine Entrypoint */}\n                <button\n                  id=\"menu-origins-link\"\n                  onClick={() => selectCollectionLine(\"origins\")}\n                  className={`w-full text-left uppercase group block focus:outline-none ${\n                    currentCollection === \"origins\" ? \"text-[#E6A219]\" : \"text-[#050505]\"\n                  }`}\n                >\n                  <p className=\"font-display tracking-[0.2em] text-[11px] font-semibold text-[#A8A39D] group-hover:text-[#E6A219] transition-colors\">\n                    01 // Entrypoint\n                  </p>\n                  <h3 className=\"font-serif italic text-2xl mt-1 tracking-tight group-hover:translate-x-1.5 transition-transform duration-300\">\n                    L\'Origine\n                  </h3>\n                  <p className=\"text-[10px] text-[#737373] mt-0.5 normal-case font-light\">\n                    Visualiser le portail d\'accueil double division.\n                  </p>\n                </button>\n\n                {/* Haute Couture */}\n                <button\n                  id=\"menu-couture-link\"\n                  onClick={() => selectCollectionLine(\"couture\")}\n                  className={`w-full text-left uppercase group block focus:outline-none ${\n                    currentCollection === \"couture\" ? \"text-[#E6A219]\" : \"text-[#050505]\"\n                  }`}\n                >\n                  <p className=\"font-display tracking-[0.2em] text-[11px] font-semibold text-[#A8A39D] group-hover:text-[#E6A219] transition-colors\">\n                    02 // Ligne Sculpt\303\251e\n                  </p>\n                  <h3 className=\"font-serif italic text-2xl mt-1 tracking-tight group-hover:translate-x-1.5 transition-transform duration-300\">\n                    Haute Couture\n                  </h3>\n                  <p className=\"text-[10px] text-[#737373] mt-0.5 normal-case font-light\">\n                    Manteau Architecte, vestes taill\303\251es et robes g\303\251om\303\251triques.\n                  </p>\n                </button>\n\n                {/* L\'Ecrin De Soie */}\n                <button\n                  id=\"menu-ecrin-link\"\n                  onClick={() => selectCollectionLine(\"ecrin\")}\n                  className={`w-full text-left uppercase group block focus:outline-none ${\n                    currentCollection === \"ecrin\" ? \"text-[#e84c30]\" : \"text-[#050505]\"\n                  }`}\n                >\n                  <p className=\"font-display tracking-[0.2em] text-[11px] font-semibold text-[#A8A39D] group-hover:text-[#e84c30] transition-colors\">\n                    03 // Joaillerie fine\n                  </p>\n                  <h3 className=\"font-serif italic text-2xl mt-1 tracking-tight group-hover:translate-x-1.5 transition-transform duration-300\">\n                    L\'\303\211crin de Soie\n                  </h3>\n                  <p className=\"text-[10px] text-[#737373] mt-0.5 normal-case font-light\">\n                    Alliances de perles de Pacifique et cha\303\256nages en vermeil d\'or.\n                  </p>\n                </button>\n\n                {/* L\'H\303\251ritage */}\n                <button\n                  id=\"menu-heritage-link\"\n                  onClick={() => selectCollectionLine(\"heritage\")}\n                  className={`w-full text-left uppercase group block focus:outline-none ${\n                    currentCollection === \"heritage\" ? \"text-[#b84b14]\" : \"text-[#050505]\"\n                  }`}\n                >\n                  <p className=\"font-display tracking-[0.2em] text-[11px] font-semibold text-[#A8A39D] group-hover:text-[#b84b14] transition-colors\">\n                    04 // Modest Apparel\n                  </p>\n                  <h3 className=\"font-serif italic text-2xl mt-1 tracking-tight group-hover:translate-x-1.5 transition-transform duration-300\">\n                    L\'H\303\251ritage\n                  </h3>\n                  <p className=\"text-[10px] text-[#737373] mt-0.5 normal-case font-light\">\n                    En m\303\251moire de Marieme Fall. Abayas de soie et voiles drap\303\251s.\n                  </p>\n                </button>\n              </div>\n\n              {/* Sidebar footer block Info */}\n              <div className=\"border-t border-[#050505]/10 pt-6 text-[10px] tracking-widest text-[#9C8B89] uppercase font-semibold flex flex-col gap-2 bg-transparent\">\n                <div className=\"flex items-center gap-1.5\">\n                  <Info className=\"w-3.5 h-3.5 text-[#E6A219]\" />\n                  <span>Dakar / Paris / Londres</span>\n                </div>\n                <div className=\"text-[9px] text-[#A8A39D] font-light normal-case\">\n                  \302\251 {new Date().getFullYear()} @ Maison Myriam Veil. Tous droits r\303\251serv\303\251s.\n                </div>\n              </div>\n            </nav>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
