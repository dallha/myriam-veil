    replacement_chunks {
      target_content: "  return (\n    <div className=\"fixed inset-0 z-50 overflow-hidden font-sans\">\n      {/* Backdrop */}\n      <div\n        id=\"cart-backdrop\"\n        onClick={onClose}\n        className=\"absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-300\"\n      />\n\n      {/* Main Drawer Shell */}\n      <div \n        id=\"cart-drawer-container\"\n        className=\"absolute inset-y-0 right-0 max-w-[480px] w-full bg-[#f8f7f6] flex flex-col shadow-2xl border-l border-[#050505] animate-fade-in-right transform transition-transform duration-300 h-full\"\n      >\n        {/* Success / Checkout screen */}\n        {orderPlaced ? (\n          <div className=\"flex-1 flex flex-col items-center justify-center p-8 text-center bg-[#F4EAE8]\">\n            <span className=\"text-5xl font-serif italic text-[#E6A219] mb-6 animate-pulse\">L\'\303\211l\303\251gance</span>\n            <div className=\"w-16 h-[1px] bg-[#050505] mb-6\"></div>\n            <h3 className=\"font-display font-bold uppercase tracking-[0.2em] text-lg text-[#050505] mb-2\">\n              Merci pour votre commande\n            </h3>\n            <p className=\"text-sm font-light text-[#737373] tracking-wide max-w-xs uppercase\">\n              Votre archive portable est en cours de pr\303\251paration dans nos ateliers.\n            </p>\n            <div className=\"mt-8 text-xs font-mono text-[#A8A39D]\">\n              N\302\260 DE COMMANDE: MV-{Math.floor(Math.random() * 90000) + 10000}\n            </div>\n          </div>\n        ) : (\n          <>\n            {/* Drawer Header */}\n            <header className=\"flex-shrink-0 border-b border-[#050505] bg-[#f8f7f6] px-6 py-6 flex justify-between items-start\">\n              <div>\n                <h2 className=\"font-display font-bold text-2xl md:text-3xl tracking-tight uppercase leading-none text-[#050505]\">\n                  Le Panier\n                </h2>\n                <p className=\"text-[#737373] text-sm tracking-widest uppercase font-serif italic mt-1 pb-1\">\n                  [{totalItemCount} {totalItemCount > 1 ? \"pi\303\250ces\" : \"pi\303\250ce\"}]\n                </p>\n              </div>\n              <button\n                id=\"close-cart-drawer-btn\"\n                aria-label=\"Fermer\"\n                onClick={onClose}\n                className=\"text-[#050505] hover:text-[#E6A219] transition-colors p-1\"\n              >\n                <X className=\"w-7 h-7 stroke-[1.5]\" />\n              </button>\n            </header>\n\n            {/* Cart Items List */}\n            <section className=\"flex-1 overflow-y-auto divide-y divide-[#050505]/10 no-scrollbar bg-[#f8f7f6]\">\n              {cartItems.length === 0 ? (\n                <div className=\"h-full flex flex-col items-center justify-center p-12 text-center\">\n                  <ShoppingBag className=\"w-12 h-12 mb-6 text-[#9C8B89] stroke-[1.2]\" />\n                  <p className=\"font-display font-medium uppercase tracking-widest text-base text-[#050505] mb-2\">\n                    Votre panier est vide.\n                  </p>\n                  <p className=\"text-xs text-[#737373] uppercase tracking-wider\">\n                    L\'\303\251l\303\251gance vous attend.\n                  </p>\n                  <button\n                    id=\"cart-shop-now-btn\"\n                    onClick={onClose}\n                    className=\"mt-8 border border-[#050505] px-8 py-3.5 text-xs font-bold uppercase tracking-widest hover:bg-[#050505] hover:text-[#f8f7f6] transition-colors duration-300 rounded-sm\"\n                  >\n                    D\303\251couvrir les pi\303\250ces\n                  </button>\n                </div>\n              ) : (\n                cartItems.map((item, index) => (\n                  <article\n                    key={`${item.product.id}-${item.selectedSize || index}`}\n                    className=\"p-6 flex gap-6 relative group bg-[#f8f7f6] transition-colors\"\n                  >\n                    {/* Product Image preview */}\n                    <div className=\"w-[90px] h-[115px] md:w-[100px] md:h-[130px] shrink-0 bg-[#EBE9E4] relative overflow-hidden rounded-sm border border-black/5\">\n                      <img\n                        alt={item.product.name}\n                        className=\"w-full h-full object-cover object-center grayscale contrast-110 group-hover:scale-105 transition-transform duration-700\"\n                        src={item.product.imageUrl}\n                        referrerPolicy=\"no-referrer\"\n                      />\n                    </div>\n\n                    {/* Product Metadata & Action */}\n                    <div className=\"flex flex-col justify-between flex-1\">\n                      <div>\n                        <div className=\"flex justify-between items-start gap-2\">\n                          <h3 className=\"font-display font-bold text-sm md:text-base tracking-wide uppercase text-[#050505]\">\n                            {item.product.name}\n                          </h3>\n                        </div>\n                        <p className=\"text-xs text-[#737373] uppercase tracking-widest mt-1\">\n                          {item.selectedSize ? `T.${item.selectedSize}` : \"Unique\"} // {item.product.category || \"Couture\"}\n                        </p>\n                      </div>\n\n                      {/* Controls and prices */}\n                      <div className=\"flex items-end justify-between w-full mt-4\">\n                        {/* Utilitarian controls */}\n                        <div className=\"flex items-center border border-[#050505] rounded-none bg-[#f8f7f6]\">\n                          <button\n                            id={`decrease-qty-${item.product.id}`}\n                            aria-label=\"Diminuer\"\n                            onClick={() => onUpdateQuantity(item.product.id, item.quantity - 1, item.selectedSize)}\n                            className=\"w-8 h-8 flex items-center justify-center text-sm font-medium hover:bg-[#050505] hover:text-white transition-colors cursor-pointer\"\n                          >\n                            <Minus className=\"w-3.5 h-3.5\" />\n                          </button>\n                          <span className=\"w-8 h-8 flex items-center justify-center text-xs font-semibold border-x border-[#050505] text-[#050505]\">\n                            {item.quantity}\n                          </span>\n                          <button\n                            id={`increase-qty-${item.product.id}`}\n                            aria-label=\"Augmenter\"\n                            onClick={() => onUpdateQuantity(item.product.id, item.quantity + 1, item.selectedSize)}\n                            className=\"w-8 h-8 flex items-center justify-center text-sm font-medium hover:bg-[#050505] hover:text-white transition-colors cursor-pointer\"\n                          >\n                            <Plus className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </div>\n\n                        {/* Cost */}\n                        <div className=\"font-display font-medium text-base md:text-lg text-[#050505]\">\n                          {item.product.price * item.quantity} \342\202\254\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Absolute Trash Trigger */}\n                    <button\n                      id={`remove-item-${item.product.id}`}\n                      onClick={() => onRemoveItem(item.product.id, item.selectedSize)}\n                      className=\"absolute top-6 right-6 text-[#737373] hover:text-red-600 transition-colors p-1\"\n                      title=\"Retirer l\'article\"\n                    >\n                      <Trash2 className=\"w-4 h-4\" />\n                    </button>\n                  </article>\n                ))\n              )}\n            </section>\n\n            {/* Receipt checkout specifications */}\n            {cartItems.length > 0 && (\n              <footer className=\"flex-shrink-0 bg-[#EBE9E4] border-t border-[#050505] flex flex-col\">\n                {/* Micro receipt details */}\n                <div className=\"px-6 py-5 border-b border-[#050505]/20 space-y-2.5 text-xs text-[#737373] uppercase tracking-wider font-sans\">\n                  <div className=\"flex justify-between items-center bg-[#EBE9E4]\">\n                    <span>Sous-total</span>\n                    <span className=\"font-medium text-[#050505]\">{subtotal} \342\202\254</span>\n                  </div>\n                  <div className=\"flex justify-between items-center bg-[#EBE9E4]\">\n                    <span>Livraison</span>\n                    <span className=\"italic font-serif text-[#050505] tracking-normal text-[11px] lowercase first-letter:uppercase\">\n                      Calcul\303\251e \303\240 l\'\303\251tape suivante\n                    </span>\n                  </div>\n                  <div className=\"flex justify-between items-center bg-[#EBE9E4]\">\n                    <span>Taxes (TVA inc.)</span>\n                    <span className=\"font-medium text-[#050505]\">{taxesInc} \342\202\254</span>\n                  </div>\n                </div>\n\n                {/* Majestic total */}\n                <div className=\"px-6 py-6 flex justify-between items-end bg-[#f8f7f6]\">\n                  <span className=\"font-display font-bold uppercase text-xs tracking-[0.2em] text-[#050505]\">\n                    Total\n                  </span>\n                  <span className=\"font-display font-semibold text-3xl md:text-4xl text-[#E6A219] leading-none\">\n                    {subtotal} \342\202\254\n                  </span>\n                </div>\n\n                {/* Massive CTA */}\n                <button\n                  id=\"checkout-confirm-btn\"\n                  onClick={handleCheckout}\n                  disabled={isCheckingOut}\n                  className=\"w-full bg-[#E6A219] text-[#050505] py-5 px-6 font-display font-bold text-sm md:text-base uppercase tracking-[0.2em] hover:bg-[#050505] hover:text-[#E6A219] transition-all duration-300 flex items-center justify-between cursor-pointer disabled:opacity-50\"\n                >\n                  <span>{isCheckingOut ? \"Traitement...\" : \"Valider la commande\"}</span>\n                  <ArrowRight className=\"w-5 h-5 ml-1 animate-pulse\" />\n                </button>\n              </footer>\n            )}\n          </>\n        )}\n      </div>\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"fixed inset-0 z-50 overflow-hidden font-sans\">\n      {/* Backdrop */}\n      <div\n        id=\"cart-backdrop\"\n        onClick={onClose}\n        className=\"absolute inset-0 bg-black/60 backdrop-blur-md transition-opacity duration-300\"\n      />\n\n      {/* Main Drawer Shell (Immersive Glass) */}\n      <div \n        id=\"cart-drawer-container\"\n        className=\"absolute inset-y-0 right-0 max-w-[480px] w-full bg-[#02040a]/90 backdrop-blur-3xl flex flex-col shadow-2xl border-l border-white/10 animate-fade-in-right transform transition-transform duration-300 h-full text-slate-300\"\n      >\n        {/* Success / Checkout screen */}\n        {orderPlaced ? (\n          <div className=\"flex-1 flex flex-col items-center justify-center p-8 text-center bg-gradient-to-br from-slate-950 via-black to-fuchsia-950/30\">\n            <span className=\"text-5xl font-serif italic bg-gradient-to-r from-blue-400 to-fuchsia-400 bg-clip-text text-transparent mb-6 animate-pulse\">L\'\303\211l\303\251gance</span>\n            <div className=\"w-16 h-[1px] bg-white/20 mb-6\"></div>\n            <h3 className=\"font-display font-bold uppercase tracking-[0.2em] text-lg text-white mb-2\">\n              Merci pour votre commande\n            </h3>\n            <p className=\"text-sm font-light text-slate-400 tracking-wide max-w-xs uppercase\">\n              Votre archive portable est en cours de pr\303\251paration dans nos ateliers.\n            </p>\n            <div className=\"mt-8 text-xs font-mono text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1.5 rounded-full\">\n              N\302\260 DE COMMANDE: MV-{Math.floor(Math.random() * 90000) + 10000}\n            </div>\n          </div>\n        ) : (\n          <>\n            {/* Drawer Header */}\n            <header className=\"flex-shrink-0 border-b border-white/10 bg-[#02040a]/40 px-6 py-6 flex justify-between items-start\">\n              <div>\n                <h2 className=\"font-display font-bold text-2xl md:text-3xl tracking-tight uppercase leading-none text-white\">\n                  Le Panier\n                </h2>\n                <p className=\"text-slate-400 text-sm tracking-widest uppercase font-serif italic mt-1 pb-1\">\n                  [{totalItemCount} {totalItemCount > 1 ? \"pi\303\250ces\" : \"pi\303\250ce\"}]\n                </p>\n              </div>\n              <button\n                id=\"close-cart-drawer-btn\"\n                aria-label=\"Fermer\"\n                onClick={onClose}\n                className=\"text-slate-400 hover:text-white transition-colors p-1\"\n              >\n                <X className=\"w-7 h-7 stroke-[1.5]\" />\n              </button>\n            </header>\n\n            {/* Cart Items List */}\n            <section className=\"flex-1 overflow-y-auto divide-y divide-white/5 no-scrollbar bg-black/20\">\n              {cartItems.length === 0 ? (\n                <div className=\"h-full flex flex-col items-center justify-center p-12 text-center\">\n                  <ShoppingBag className=\"w-12 h-12 mb-6 text-slate-500 stroke-[1.2]\" />\n                  <p className=\"font-display font-medium uppercase tracking-widest text-base text-white mb-2\">\n                    Votre panier est vide.\n                  </p>\n                  <p className=\"text-xs text-slate-400 uppercase tracking-wider\">\n                    L\'\303\251l\303\251gance vous attend.\n                  </p>\n                  <button\n                    id=\"cart-shop-now-btn\"\n                    onClick={onClose}\n                    className=\"mt-8 border border-white/10 bg-white/5 text-white px-8 py-3.5 text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all duration-300 rounded-sm\"\n                  >\n                    D\303\251couvrir les pi\303\250ces\n                  </button>\n                </div>\n              ) : (\n                cartItems.map((item, index) => (\n                  <article\n                    key={`${item.product.id}-${item.selectedSize || index}`}\n                    className=\"p-6 flex gap-6 relative group bg-white/[0.01] transition-colors hover:bg-white/[0.03]\"\n                  >\n                    {/* Product Image preview */}\n                    <div className=\"w-[90px] h-[115px] md:w-[100px] md:h-[130px] shrink-0 bg-slate-900 relative overflow-hidden rounded-sm border border-white/10\">\n                      <img\n                        alt={item.product.name}\n                        className=\"w-full h-full object-cover object-center grayscale contrast-110 group-hover:grayscale-0 group-hover:scale-105 transition-transform duration-700\"\n                        src={item.product.imageUrl}\n                        referrerPolicy=\"no-referrer\"\n                      />\n                    </div>\n\n                    {/* Product Metadata & Action */}\n                    <div className=\"flex flex-col justify-between flex-1\">\n                      <div>\n                        <div className=\"flex justify-between items-start gap-2\">\n                          <h3 className=\"font-display font-medium text-sm md:text-base tracking-wide uppercase text-white\">\n                            {item.product.name}\n                          </h3>\n                        </div>\n                        <p className=\"text-[11px] text-slate-400 uppercase tracking-widest mt-1\">\n                          {item.selectedSize ? `T.${item.selectedSize}` : \"Unique\"} // {item.product.category || \"Couture\"}\n                        </p>\n                      </div>\n\n                      {/* Controls and prices */}\n                      <div className=\"flex items-end justify-between w-full mt-4\">\n                        {/* Utilitarian controls */}\n                        <div className=\"flex items-center border border-white/10 rounded-sm overflow-hidden bg-black/30\">\n                          <button\n                            id={`decrease-qty-${item.product.id}`}\n                            aria-label=\"Diminuer\"\n                            onClick={() => onUpdateQuantity(item.product.id, item.quantity - 1, item.selectedSize)}\n                            className=\"w-8 h-8 flex items-center justify-center text-sm font-medium text-slate-400 hover:bg-white/5 hover:text-white transition-colors cursor-pointer\"\n                          >\n                            <Minus className=\"w-3.5 h-3.5\" />\n                          </button>\n                          <span className=\"w-8 h-8 flex items-center justify-center text-xs font-semibold border-x border-white/10 text-white\">\n                            {item.quantity}\n                          </span>\n                          <button\n                            id={`increase-qty-${item.product.id}`}\n                            aria-label=\"Augmenter\"\n                            onClick={() => onUpdateQuantity(item.product.id, item.quantity + 1, item.selectedSize)}\n                            className=\"w-8 h-8 flex items-center justify-center text-sm font-medium text-slate-400 hover:bg-white/5 hover:text-white transition-colors cursor-pointer\"\n                          >\n                            <Plus className=\"w-3.5 h-3.5\" />\n                          </button>\n                        </div>\n\n                        {/* Cost */}\n                        <div className=\"font-display font-medium text-base md:text-lg text-white\">\n                          {item.product.price * item.quantity} \342\202\254\n                        </div>\n                      </div>\n                    </div>\n\n                    {/* Absolute Trash Trigger */}\n                    <button\n                      id={`remove-item-${item.product.id}`}\n                      onClick={() => onRemoveItem(item.product.id, item.selectedSize)}\n                      className=\"absolute top-6 right-6 text-slate-500 hover:text-red-400 transition-colors p-1\"\n                      title=\"Retirer l\'article\"\n                    >\n                      <Trash2 className=\"w-4 h-4\" />\n                    </button>\n                  </article>\n                ))\n              )}\n            </section>\n\n            {/* Receipt checkout specifications */}\n            {cartItems.length > 0 && (\n              <footer className=\"flex-shrink-0 bg-[#02040a]/90 border-t border-white/10 flex flex-col\">\n                {/* Micro receipt details */}\n                <div className=\"px-6 py-5 border-b border-white/5 space-y-2.5 text-xs text-slate-400 uppercase tracking-wider font-sans\">\n                  <div className=\"flex justify-between items-center\">\n                    <span>Sous-total</span>\n                    <span className=\"font-medium text-white\">{subtotal} \342\202\254</span>\n                  </div>\n                  <div className=\"flex justify-between items-center\">\n                    <span>Livraison</span>\n                    <span className=\"italic font-serif text-slate-400 tracking-normal text-[11px] lowercase first-letter:uppercase\">\n                      Calcul\303\251e \303\240 l\'\303\251tape suivante\n                    </span>\n                  </div>\n                  <div className=\"flex justify-between items-center\">\n                    <span>Taxes (TVA inc.)</span>\n                    <span className=\"font-medium text-white\">{taxesInc} \342\202\254</span>\n                  </div>\n                </div>\n\n                {/* Majestic total */}\n                <div className=\"px-6 py-6 flex justify-between items-end bg-[#02040a]/40\">\n                  <span className=\"font-display font-medium uppercase text-xs tracking-[0.2em] text-slate-400\">\n                    Total\n                  </span>\n                  <span className=\"font-display font-semibold text-3xl md:text-4xl text-fuchsia-400 leading-none\">\n                    {subtotal} \342\202\254\n                  </span>\n                </div>\n\n                {/* Massive CTA */}\n                <button\n                  id=\"checkout-confirm-btn\"\n                  onClick={handleCheckout}\n                  disabled={isCheckingOut}\n                  className=\"w-full bg-gradient-to-r from-blue-600 to-fuchsia-600 text-white py-5 px-6 font-display font-bold text-sm md:text-base uppercase tracking-[0.2em] hover:brightness-110 active:scale-[0.98] transition-all duration-300 flex items-center justify-between cursor-pointer disabled:opacity-50\"\n                >\n                  <span>{isCheckingOut ? \"Traitement...\" : \"Valider la commande\"}</span>\n                  <ArrowRight className=\"w-5 h-5 ml-1 animate-pulse\" />\n                </button>\n              </footer>\n            )}\n          </>\n        )}\n      </div>\n    </div>\n  );"
