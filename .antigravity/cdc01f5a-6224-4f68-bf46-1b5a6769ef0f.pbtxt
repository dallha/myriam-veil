    instruction: "Add Immersive UI classes like deep dark theme, glassmorphism, glows, and custom scrollbar styles to src/index.css"
    replacement_infos {
      original_chunk {
        target_content: "@import url(\'https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Jost:ital,wght@0,100..900;1,100..900&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Jost\", \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Syne\", sans-serif;\n  --font-serif: \"EB Garamond\", serif;\n}\n\n/* Custom Editorial Keyframe Animations */\n@keyframes zoomOut {\n  0% { transform: scale(1.1); }\n  100% { transform: scale(1); }\n}\n\n@keyframes fadeIn {\n  0% { opacity: 0; transform: translateY(12px); }\n  100% { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes fadeInRight {\n  0% { opacity: 0; transform: translateX(100%); }\n  100% { opacity: 1; transform: translateX(0); }\n}\n\n@keyframes marquee {\n  0% { transform: translateX(0%); }\n  100% { transform: translateX(-50%); }\n}\n\n/* Utility Animations */\n.animate-slow-zoom {\n  animation: zoomOut 16s ease-out forwards;\n}\n\n.animate-fade-in {\n  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n\n.animate-fade-in-right {\n  animation: fadeInRight 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n\n.animate-marquee {\n  animation: marquee 20s linear infinite;\n}\n\n/* Custom Scrollbar configurations */\n.hide-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.hide-scrollbar {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n\n/* Staggered Masonry Layout for Fine Jewelry Catalogue */\n.masonry-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 16px;\n  align-items: start;\n}\n\n.masonry-col-1 {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n  margin-top: 40px; /* offset stagger */\n}\n\n.masonry-col-2 {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n}\n\n/* Asymmetric corner shape for Fine Jewelry Catalog */\n.img-asymmetric {\n  border-top-left-radius: 24px;\n  border-bottom-right-radius: 24px;\n  border-top-right-radius: 4px;\n  border-bottom-left-radius: 4px;\n}\n\n.card-radius {\n  border-radius: 24px 0 24px 0;\n}"
        replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Jost:ital,wght@0,100..900;1,100..900&family=Fira+Code:wght@300;400;500;600;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Jost\", \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Syne\", sans-serif;\n  --font-serif: \"EB Garamond\", serif;\n  --font-mono: \"Fira Code\", \"JetBrains Mono\", monospace;\n}\n\nbody {\n  background-color: #02040a;\n  color: #cbd5e1; /* slate-300 */\n}\n\n/* Glassmorphism for panels */\n.panel-glass {\n  background: rgba(255, 255, 255, 0.02);\n  backdrop-filter: blur(24px);\n  -webkit-backdrop-filter: blur(24px);\n  border: 1px solid rgba(255, 255, 255, 0.08);\n}\n\n.panel-glass-deep {\n  background: rgba(2, 4, 10, 0.85);\n  backdrop-filter: blur(32px);\n  -webkit-backdrop-filter: blur(32px);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.panel-glass-glow {\n  background: rgba(255, 255, 255, 0.03);\n  backdrop-filter: blur(24px);\n  border: 1px solid rgba(59, 130, 246, 0.2); /* blue glow border */\n  box-shadow: 0 0 25px rgba(59, 130, 246, 0.05);\n}\n\n.btn-immersive-primary {\n  background: linear-gradient(135deg, #3b82f6 0%, #d946ef 100%); /* Blue to Fuchsia */\n  color: #ffffff;\n  box-shadow: 0 4px 20px rgba(59, 130, 246, 0.3);\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.btn-immersive-primary:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 8px 30px rgba(59, 130, 246, 0.5), 0 0 15px rgba(217, 70, 239, 0.3);\n}\n\n.btn-immersive-secondary {\n  background: rgba(255, 255, 255, 0.05);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  color: #ffffff;\n  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);\n}\n\n.btn-immersive-secondary:hover {\n  background: rgba(255, 255, 255, 0.1);\n  border-color: rgba(255, 255, 255, 0.2);\n}\n\n/* Custom Editorial Keyframe Animations */\n@keyframes zoomOut {\n  0% { transform: scale(1.1); }\n  100% { transform: scale(1); }\n}\n\n@keyframes fadeIn {\n  0% { opacity: 0; transform: translateY(12px); }\n  100% { opacity: 1; transform: translateY(0); }\n}\n\n@keyframes fadeInRight {\n  0% { opacity: 0; transform: translateX(100%); }\n  100% { opacity: 1; transform: translateX(0); }\n}\n\n@keyframes marquee {\n  0% { transform: translateX(0%); }\n  100% { transform: translateX(-50%); }\n}\n\n/* Utility Animations */\n.animate-slow-zoom {\n  animation: zoomOut 16s ease-out forwards;\n}\n\n.animate-fade-in {\n  animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n\n.animate-fade-in-right {\n  animation: fadeInRight 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n}\n\n.animate-marquee {\n  animation: marquee 20s linear infinite;\n}\n\n/* Custom Scrollbar configurations */\n.hide-scrollbar::-webkit-scrollbar {\n  display: none;\n}\n.hide-scrollbar {\n  -ms-overflow-style: none;\n  scrollbar-width: none;\n}\n\n/* Custom scrollbar for desktop/oversized panels */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n::-webkit-scrollbar-track {\n  background: rgba(2, 4, 10, 0.5);\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 99px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* Staggered Masonry Layout for Fine Jewelry Catalogue */\n.masonry-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 16px;\n  align-items: start;\n}\n\n.masonry-col-1 {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n  margin-top: 40px; /* offset stagger */\n}\n\n.masonry-col-2 {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n}\n\n/* Asymmetric corner shape for Fine Jewelry Catalog */\n.img-asymmetric {\n  border-top-left-radius: 24px;\n  border-bottom-right-radius: 24px;\n  border-top-right-radius: 4px;\n  border-bottom-left-radius: 4px;\n}\n\n.card-radius {\n  border-radius: 24px 0 24px 0;\n}"
