  file_change {
    absolute_path_uri: "file:///src/components/CollectionEcrin.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { useState } from \"react\";\nimport { Product } from \"../types\";\nimport { ArrowLeft, ChevronDown, Heart, Plus, ShoppingBag } from \"lucide-react\";\n\ninterface CollectionEcrinProps {\n  products: Product[];\n  onAddToCart: (product: Product) => void;\n}\n\nexport default function CollectionEcrin({ products, onAddToCart }: CollectionEcrinProps) {\n  // Navigation: \'home\' (Screen 3) | \'catalog\' (Screen 8) | \'detail\' (Screen 9)\n  const [stage, setStage] = useState<\"home\" | \"catalog\" | \"detail\">(\"home\");\n  const [selectedProduct, setSelectedProduct] = useState<Product | null>(null);\n\n  // Filter criteria for L\'\303\211crin\n  const [selectedCategory, setSelectedCategory] = useState<string>(\"Toutes les pi\303\250ces\");\n  const categoriesList = [\"Toutes les pi\303\250ces\", \"Bagues\", \"Colliers\", \"Boucles d\'oreilles\"];\n\n  // Heart state toggle representation\n  const [isWished, setIsWished] = useState(false);\n\n  // Detail View configurations\n  const [activeImgIndex, setActiveImgIndex] = useState(0);\n\n  const filteredProducts = products.filter((p) => {\n    if (selectedCategory === \"Toutes les pi\303\250ces\") return true;\n    return p.category === selectedCategory || (p.category === \"Boucles d\'oreilles\" && selectedCategory === \"Boucles d\'oreilles\");\n  });\n\n  const handleProductSelect = (prod: Product) => {\n    setSelectedProduct(prod);\n    setActiveImgIndex(0);\n    setStage(\"detail\");\n  };\n\n  const handleAddWithFeedback = (prod: Product) => {\n    onAddToCart(prod);\n    const textSpan = document.getElementById(\"add-ecrin-text\");\n    if (textSpan) {\n      textSpan.innerText = \"AJOUT\303\211 \303\200 L\'\303\211CRiN\";\n      setTimeout(() => {\n        if (textSpan) textSpan.innerText = \"Ajouter \303\240 l\'\303\251crin\";\n      }, 1500);\n    }\n  };\n\n  return (\n    <div className=\"w-full bg-[#f8f6f6] min-h-screen text-[#4A3B39] font-sans\">\n      {/* 1. L\'\303\211CRIN HOME SCREEN (Screen 3) */}\n      {stage === \"home\" && (\n        <div className=\"page-enter select-none w-full bg-[#FDFBF7]\">\n          {/* Hero Section Container */}\n          <header className=\"relative w-full h-[80vh] flex flex-col justify-end items-center pb-24\">\n            {/* Ambient gold/rose background banner */}\n            <div\n              className=\"absolute inset-0 z-0 bg-cover bg-center transition-transform duration-[15000ms] scale-110 animate-slow-zoom\"\n              style={{\n                backgroundImage: `url(\'https://lh3.googleusercontent.com/aida-public/AB6AXuDGTaNWNRJwSBRA-fNaWvRzqGDGwktA1IVjav_7aqS92iRqp2-2tK6EZmbVUn4wSb9Iffs5pERFgWcRvK0-vt6alUAfExiMMnX6NfKDtMFZEmZH_eQ39eGQpIXYdG82wWmNva9oU-bJUk7cg9u21qrSWJZijkYuuoYfYJ2V8pG9_UhMj68pXloucahWitskcIzmaQPtBrzj8sZ1duG4j__OvlqfkpOdKhq0y5ZNvTkeSO3qRuUyJ3Q51JnI5vhpC3UDMbTJ8RHIV4rP\')`,\n              }}\n            />\n            {/* Dark elegant Overlay */}\n            <div className=\"absolute inset-0 z-10 bg-gradient-to-t from-black/60 via-transparent to-black/20\" />\n\n            {/* Central Callout Area */}\n            <div className=\"relative z-20 text-center px-6 w-full flex flex-col items-center gap-6\">\n              <p className=\"text-white/95 font-serif italic text-xl tracking-wide font-light drop-shadow-sm\">\n                La nouvelle collection\n              </p>\n              <button\n                id=\"discover-ecrin-btn\"\n                onClick={() => setStage(\"catalog\")}\n                className=\"bg-white/95 backdrop-blur-md text-[#4A3B39] uppercase text-xs tracking-[2px] py-4 px-10 rounded-full hover:bg-white hover:scale-105 transition-all duration-300 shadow-xl cursor-pointer font-semibold animate-pulse\"\n              >\n                D\303\251couvrir\n              </button>\n            </div>\n          </header>\n\n          {/* Quick Collection Preview slider */}\n          <section className=\"py-16 bg-[#FDFBF7] w-full rounded-t-[40px] shadow-[0_-10px_40px_rgba(0,0,0,0.05)] relative z-10 -mt-8\">\n            <div className=\"px-6 mb-8 flex justify-between items-end\">\n              <h2 className=\"font-serif text-2xl text-[#4A3B39] italic\">L\'Essence</h2>\n              <button\n                onClick={() => setStage(\"catalog\")}\n                className=\"text-[#9C8B89] text-[10px] uppercase tracking-widest hover:text-[#4A3B39] border-b border-[#9C8B89]/20 pb-0.5 transition-colors\"\n              >\n                Voir tout\n              </button>\n            </div>\n\n            {/* Carousel slider cards */}\n            <div className=\"w-full overflow-x-auto hide-scrollbar pl-6 pr-6 pb-4\">\n              <div className=\"flex gap-6 w-max\">\n                {products.slice(0, 3).map((prod) => (\n                  <article\n                    key={prod.id}\n                    onClick={() => handleProductSelect(prod)}\n                    className=\"w-[70vw] max-w-[260px] flex flex-col gap-4 group cursor-pointer\"\n                  >\n                    <div className=\"w-full aspect-[4/5] bg-[#F4EAE8] overflow-hidden relative shadow-lg rounded-t-[20px] rounded-br-[20px] border border-[#F4EAE8]/30\">\n                      <img\n                        alt={prod.name}\n                        className=\"absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"\n                        src={prod.imageUrl}\n                        referrerPolicy=\"no-referrer\"\n                      />\n                    </div>\n                    <div className=\"flex flex-col items-center text-center px-1\">\n                      <h3 className=\"font-serif text-base text-[#4A3B39] group-hover:text-[#e84c30] transition-colors\">\n                        {prod.name}\n                      </h3>\n                      <p className=\"text-xs text-[#9C8B89] mt-0.5 font-light\">\n                        {prod.price} \342\202\254\n                      </p>\n                    </div>\n                  </article>\n                ))}\n              </div>\n            </div>\n          </section>\n        </div>\n      )}\n\n      {/* 2. L\'\303\211CRIN CATALOG DIRECTORY VIEW (Screen 8) */}\n      {stage === \"catalog\" && (\n        <div className=\"page-enter w-full\">\n          {/* Breadcrumb row & collection headers */}\n          <div className=\"px-6 py-4 border-b border-[#F4EAE8]/60 flex justify-between items-center bg-[#f8f6f6]\">\n            <button\n              onClick={() => setStage(\"home\")}\n              className=\"text-xs font-bold uppercase tracking-wider flex items-center gap-1 hover:text-[#e84c30] transition-colors\"\n            >\n              <ArrowLeft className=\"w-3.5 h-3.5\" /> Accueil\n            </button>\n            <span className=\"font-serif italic text-lg text-[#4A3B39]\">Le Catalogue</span>\n            <div className=\"w-12\"></div>\n          </div>\n\n          {/* Luxury Filter tabs */}\n          <div className=\"flex gap-2.5 px-6 py-4 overflow-x-auto hide-scrollbar bg-[#f8f6f6]/95 border-b border-[#F4EAE8]/80 sticky top-16 z-20\">\n            {categoriesList.map((cat) => (\n              <button\n                key={cat}\n                onClick={() => setSelectedCategory(cat)}\n                className={`flex h-9 shrink-0 items-center justify-center rounded-full px-5 text-[11px] font-medium uppercase tracking-widest transition-all ${\n                  selectedCategory === cat\n                    ? \"bg-[#F4EAE8] border border-[#e84c30] text-[#4A3B39] shadow-sm font-semibold\"\n                    : \"bg-[#F4EAE8]/40 border border-transparent text-[#9C8B89] hover:bg-[#F4EAE8]\"\n                }`}\n              >\n                {cat}\n              </button>\n            ))}\n          </div>\n\n          {/* Staggered Masonry Design Grid (Screen 8 style) */}\n          <main className=\"px-4 py-8 max-w-lg mx-auto\">\n            <div className=\"masonry-grid\">\n              {/* Left Column (staggered down via top-margin) */}\n              <div className=\"masonry-col-1\">\n                {filteredProducts\n                  .filter((_, idx) => idx % 2 === 0)\n                  .map((prod) => (\n                    <article\n                      key={prod.id}\n                      onClick={() => handleProductSelect(prod)}\n                      className=\"group block cursor-pointer\"\n                    >\n                      <div className=\"relative overflow-hidden img-asymmetric mb-3 bg-[#F4EAE8] aspect-[4/5] shadow-sm border border-[#F4EAE8]\">\n                        <img\n                          alt={prod.name}\n                          className=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"\n                          src={prod.imageUrl}\n                          referrerPolicy=\"no-referrer\"\n                        />\n                      </div>\n                      <div className=\"flex flex-col gap-0.5 px-1\">\n                        <h3 className=\"font-serif text-base text-[#4A3B39] group-hover:text-[#e84c30] transition-colors leading-tight\">\n                          {prod.name}\n                        </h3>\n                        <p className=\"text-xs text-[#9C8B89] font-light\">\n                          {prod.price} \342\202\254\n                        </p>\n                      </div>\n                    </article>\n                  ))}\n              </div>\n\n              {/* Right Column */}\n              <div className=\"masonry-col-2\">\n                {filteredProducts\n                  .filter((_, idx) => idx % 2 === 1)\n                  .map((prod) => (\n                    <article\n                      key={prod.id}\n                      onClick={() => handleProductSelect(prod)}\n                      className=\"group block cursor-pointer\"\n                    >\n                      <div className=\"relative overflow-hidden img-asymmetric mb-3 bg-[#F4EAE8] aspect-[3/4] shadow-sm border border-[#F4EAE8]\">\n                        <img\n                          alt={prod.name}\n                          className=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"\n                          src={prod.imageUrl}\n                          referrerPolicy=\"no-referrer\"\n                        />\n                      </div>\n                      <div className=\"flex flex-col gap-0.5 px-1\">\n                        <h3 className=\"font-serif text-base text-[#4A3B39] group-hover:text-[#e84c30] transition-colors leading-tight\">\n                          {prod.name}\n                        </h3>\n                        <p className=\"text-xs text-[#9C8B89] font-light\">\n                          {prod.price} \342\202\254\n                        </p>\n                      </div>\n                    </article>\n                  ))}\n              </div>\n            </div>\n\n            {/* Collection update note */}\n            <div className=\"mt-20 text-center pb-12\">\n              <p className=\"font-serif italic text-[#9C8B89] text-base\">La collection se renouvelle...</p>\n              <div className=\"h-px w-10 bg-[#F4EAE8] mx-auto mt-4\" />\n            </div>\n          </main>\n        </div>\n      )}\n\n      {/* 3. L\'\303\211CRIN HIGH END PRODUCT DETAIL (Screen 9) */}\n      {stage === \"detail\" && selectedProduct && (\n        <div className=\"page-enter w-full max-w-lg mx-auto pb-32\">\n          {/* Header overrides */}\n          <header className=\"absolute top-0 left-0 w-full z-20 flex justify-between items-center p-4\">\n            <button\n              onClick={() => setStage(\"catalog\")}\n              className=\"size-10 rounded-full bg-white/60 backdrop-blur-md flex items-center justify-center text-[#4A3B39] hover:bg-white transition-all shadow-sm\"\n              title=\"Retour aux bijoux\"\n            >\n              <ArrowLeft className=\"w-5 h-5\" />\n            </button>\n            <button\n              onClick={() => setIsWished(!isWished)}\n              className=\"size-10 rounded-full bg-white/60 backdrop-blur-md flex items-center justify-center text-[#e84c30] hover:bg-white transition-all shadow-sm\"\n              title=\"Ajouter aux souhaits\"\n            >\n              <Heart className={`w-5 h-5 ${isWished ? \"fill-[#e84c30]\" : \"\"}`} />\n            </button>\n          </header>\n\n          {/* Large imagery carousel */}\n          <div className=\"relative w-full h-[480px] md:h-[530px] bg-[#F4EAE8] overflow-hidden shadow-inner\">\n            <img\n              alt={selectedProduct.name}\n              className=\"w-full h-full object-cover grayscale contrast-125 transition-all duration-750\"\n              src={\n                selectedProduct.additionalImages\n                  ? selectedProduct.additionalImages[activeImgIndex]\n                  : selectedProduct.imageUrl\n              }\n              referrerPolicy=\"no-referrer\"\n            />\n\n            {/* Swiper index indicator dots */}\n            {selectedProduct.additionalImages && selectedProduct.additionalImages.length > 1 && (\n              <div className=\"absolute bottom-6 left-0 right-0 flex justify-center gap-2.5 z-10 bg-black/10 max-w-[120px] mx-auto py-1.5 px-3 rounded-full backdrop-blur-sm\">\n                {selectedProduct.additionalImages.map((_, dotIdx) => (\n                  <button\n                    key={dotIdx}\n                    onClick={() => setActiveImgIndex(dotIdx)}\n                    className={`size-2 rounded-full transition-all duration-300 ${\n                      activeImgIndex === dotIdx ? \"bg-[#e84c30] w-4\" : \"bg-white/60\"\n                    }`}\n                  />\n                ))}\n              </div>\n            )}\n          </div>\n\n          {/* Product main presentation content card */}\n          <main className=\"px-6 py-8 bg-[#f8f6f6] rounded-t-3xl -mt-6 relative z-10 shadow-[0_-15px_30px_rgba(0,0,0,0.03)] border-t border-[#F4EAE8]\">\n            <div className=\"flex justify-between items-start gap-3 mb-6\">\n              <h1 className=\"font-display font-medium text-[28px] md:text-[32px] leading-tight text-[#4A3B39] w-2/3\">\n                {selectedProduct.name}\n              </h1>\n              <span className=\"font-serif text-xl md:text-2xl text-[#e84c30] font-light tracking-wide mt-1\">\n                {selectedProduct.price} \342\202\254\n              </span>\n            </div>\n\n            {/* Mineral material luxury badges */}\n            <div className=\"flex flex-wrap gap-2 mb-8\">\n              <span className=\"px-4 py-1.5 bg-[#F4EAE8] text-[#4A3B39] text-[11px] uppercase tracking-[1px] rounded-full border border-[#D4B5B0]/30 font-semibold shadow-sm\">\n                Or Vermeil\n              </span>\n              <span className=\"px-4 py-1.5 bg-[#F4EAE8] text-[#4A3B39] text-[11px] uppercase tracking-[1px] rounded-full border border-[#D4B5B0]/30 font-semibold shadow-sm\">\n                Perle d\'eau douce\n              </span>\n            </div>\n\n            {/* Text story descriptions */}\n            <div className=\"space-y-6 text-sm font-light leading-[1.65] text-[#4A3B39]/90 text-justify\">\n              <p>\n                Comme la premi\303\250re lumi\303\250re fr\303\264lant la surface de l\'oc\303\251an. Le Collier de l\'Aube capture l\'essence d\'un matin tranquille, alliant la chaleur de l\'or vermeil \303\240 l\'\303\251clat lunaire d\'une perle d\303\251licatement s\303\251lectionn\303\251e.\n              </p>\n              <p>\n                Chaque perle est unique, glissant silencieusement le long d\'une cha\303\256ne fine qui \303\251pouse les contours de votre peau. Une pi\303\250ce pens\303\251e pour \303\252tre ressentie autant que vue, offrant une pr\303\251sence douce et lumineuse tout au long de votre journ\303\251e.\n              </p>\n            </div>\n\n            {/* Disclosures accordions */}\n            <div className=\"mt-10 border-t border-[#9C8B89]/20\">\n              <details className=\"group py-4 border-b border-[#9C8B89]/20\">\n                <summary className=\"flex justify-between items-center font-serif text-lg text-[#4A3B39] cursor-pointer list-none focus:outline-none\">\n                  <span>D\303\251tails & Entretien</span>\n                  <ChevronDown className=\"w-5 h-5 text-[#9C8B89] group-open:rotate-180 transition-transform duration-300\" />\n                </summary>\n                <div className=\"mt-3 text-xs md:text-sm text-[#9C8B89] space-y-2 pb-2 leading-relaxed whitespace-pre-line font-light\">\n                  <p>\342\200\242 Longueur du support en maille : 40cm + 5cm de rallonge</p>\n                  <p>\342\200\242 Calibre de la perle : 6-7mm diamant\303\251</p>\n                  <p>\342\200\242 \303\211viter le contact direct avec l\'eau de mer, les produits m\303\251nagers corrosifs, ou les lotions parfum\303\251es.</p>\n                </div>\n              </details>\n\n              <details className=\"group py-4 border-b border-[#9C8B89]/20\">\n                <summary className=\"flex justify-between items-center font-serif text-lg text-[#4A3B39] cursor-pointer list-none focus:outline-none\">\n                  <span>Livraison & Retours</span>\n                  <ChevronDown className=\"w-5 h-5 text-[#9C8B89] group-open:rotate-180 transition-transform duration-300\" />\n                </summary>\n                <div className=\"mt-3 text-xs md:text-sm text-[#9C8B89] space-y-2 pb-2 leading-relaxed whitewspace-pre-line font-light\">\n                  <p>\342\200\242 Option de livraison standard offerte \303\240 domicile.</p>\n                  <p>\342\200\242 Exp\303\251dition rapide sous 24h ouvr\303\251es.</p>\n                  <p>\342\200\242 D\303\251lai de r\303\251traction exceptionnel de 30 jours.</p>\n                </div>\n              </details>\n            </div>\n          </main>\n\n          {/* Sticky CTA bar for L\'\303\211crin */}\n          <div className=\"fixed bottom-0 left-0 w-full p-4 pb-6 bg-[#f8f6f6]/95 backdrop-blur-md z-30 border-t border-[#9C8B89]/15 shadow-lg\">\n            <button\n              id=\"ecrin-add-btn\"\n              onClick={() => handleAddWithFeedback(selectedProduct)}\n              className=\"w-full bg-[#e84c30] text-white font-serif text-lg py-4 rounded-lg shadow-xl transition-all duration-200 active:scale-95 flex justify-center items-center gap-3 cursor-pointer\"\n            >\n              <span id=\"add-ecrin-text\">Ajouter \303\240 l\'\303\251crin</span>\n            </button>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
