    replacement_chunks {
      target_content: "  return (\n    <div className=\"w-full bg-[#f8f7f6] min-h-screen text-[#050505]\">\n      {viewState === \"grid\" ? (\n        /* --- HIGH DESIGN GRID CATALOG (Screen 6) --- */\n        <div className=\"w-full\">\n          {/* Subheader and Filters Menu */}\n          <div className=\"border-b border-[#050505] flex justify-between items-center px-6 py-4 bg-[#f8f7f6]\">\n            <button\n              id=\"filtref-btn\"\n              onClick={() => setSelectedFilter(\"ALL\")}\n              className=\"text-xs font-bold uppercase tracking-wider flex items-center gap-1.5 border-b border-transparent hover:border-[#050505] transition-all\"\n            >\n              FILTRES + {selectedFilter !== \"ALL\" && `(${selectedFilter})`}\n            </button>\n            <span className=\"text-xs uppercase tracking-[0.2em] font-serif text-[#A8A39D]\">\n              HAUTE COUTURE\n            </span>\n            <button\n              id=\"trier-btn\"\n              className=\"text-xs font-bold uppercase tracking-wider hover:text-[#E6A219] transition-colors\"\n            >\n              TRIER\n            </button>\n          </div>\n \n          {/* Sticking Filter Chips */}\n          <div className=\"flex gap-2 px-6 py-4 overflow-x-auto hide-scrollbar bg-[#f8f7f6] border-b border-[#050505]/10\">\n            {coutureFilters.map((flt) => (\n              <button\n                key={flt}\n                onClick={() => setSelectedFilter(flt)}\n                className={`px-4 py-2 rounded-sm text-[10px] font-bold tracking-widest uppercase transition-all duration-300 border ${\n                  selectedFilter === flt\n                    ? \"bg-[#050505] text-white border-[#050505]\"\n                    : \"bg-transparent text-[#050505] border-[#050505]/20 hover:border-[#050505]\"\n                }`}\n              >\n                {flt === \"ALL\" ? \"TOUT VOIR\" : flt}\n              </button>\n            ))}\n          </div>\n \n          {/* Staggered Asymmetric Grid Layout */}\n          <main className=\"max-w-4xl mx-auto px-4 py-8 md:py-12\">\n            <div className=\"grid grid-cols-2 gap-x-4 md:gap-x-8 gap-y-12\">\n              {/* Product cards rendering */}\n              {filteredProducts.map((prod, index) => {\n                const isRightColStaggered = index % 2 === 1;\n                return (\n                  <article\n                    key={prod.id}\n                    onClick={() => handleProductClick(prod)}\n                    className={`flex flex-col group cursor-pointer transition-transform duration-500 hover:-translate-y-1 ${\n                      isRightColStaggered ? \"translate-y-6 md:translate-y-12\" : \"\"\n                    }`}\n                  >\n                    {/* Image Layer */}\n                    <div className=\"relative aspect-[3/4] bg-[#EBE9E4] overflow-hidden rounded-sm mb-4 border border-black/5\">\n                      <img\n                        alt={prod.name}\n                        className=\"w-full h-full object-cover grayscale contrast-125 transform transition-transform duration-1000 group-hover:scale-105\"\n                        src={prod.imageUrl}\n                        referrerPolicy=\"no-referrer\"\n                      />\n                      <div className=\"absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300\" />\n                    </div>\n \n                    {/* Meta details */}\n                    <div className=\"flex justify-between items-start gap-2 px-1\">\n                      <div>\n                        <h3 className=\"text-xs md:text-sm font-bold tracking-wider leading-tight text-[#050505] group-hover:text-[#E6A219] transition-colors uppercase\">\n                          {prod.name}\n                        </h3>\n                        <p className=\"text-[10px] text-[#737373] uppercase mt-0.5 tracking-widest font-mono\">\n                          {prod.category}\n                        </p>\n                      </div>\n                      <span className=\"text-xs md:text-sm font-semibold text-[#E6A219] shrink-0 font-display\">\n                        {prod.price} \342\202\254\n                      </span>\n                    </div>\n                  </article>\n                );\n              })}\n            </div>\n \n            {/* Pagination Button */}\n            <div className=\"w-full flex justify-center mt-16 md:mt-24 mb-12\">\n              <button\n                id=\"couture-load-more\"\n                onClick={() => alert(\"La collection compl\303\250te est en ligne. De nouvelles archives arrivent bient\303\264t.\")}\n                className=\"px-8 py-4 border border-[#050505] text-[#050505] text-xs font-bold uppercase tracking-widest hover:bg-[#050505] hover:text-white transition-all duration-300 rounded-sm active:scale-95\"\n              >\n                CHARGER LA SUITE\n              </button>\n            </div>\n          </main>\n        </div>\n      ) : (\n        /* --- PREMIUM OVERSZIED DETAIL PRODUCT VIEW (Screen 1) --- */\n        selectedProduct && (\n          <div className=\"w-full max-w-lg mx-auto pb-32\">\n            {/* Minimal Sub-header */}\n            <div className=\"flex items-center justify-between p-4 bg-[#f8f7f6]\">\n              <button\n                onClick={() => setViewState(\"grid\")}\n                className=\"size-8 flex items-center justify-center rounded-full bg-black/5 hover:bg-black/10 transition-colors\"\n                title=\"Retour au catalogue\"\n              >\n                <ArrowLeft className=\"w-4 h-4 text-[#050505]\" />\n              </button>\n              <span className=\"text-xs font-bold uppercase tracking-widest font-mono text-[#737373]\">\n                {selectedProduct.category}\n              </span>\n              <span className=\"w-8\"></span>\n            </div>\n \n            {/* Oversized Gallery Carousel */}\n            <section className=\"relative w-full overflow-hidden bg-[#EBE9E4]\">\n              {/* Main Carousel Screen */}\n              <div className=\"w-full aspect-[4/5] relative\">\n                <img\n                  alt={selectedProduct.name}\n                  className=\"w-full h-full object-cover grayscale contrast-125 transition-all duration-700\"\n                  src={\n                    selectedProduct.additionalImages\n                      ? selectedProduct.additionalImages[activeImageIndex]\n                      : selectedProduct.imageUrl\n                  }\n                  referrerPolicy=\"no-referrer\"\n                />\n              </div>\n \n              {/* Progress Slider Dots */}\n              {selectedProduct.additionalImages && selectedProduct.additionalImages.length > 1 && (\n                <div className=\"w-full px-6 mt-3\">\n                  <div className=\"h-[2px] bg-neutral-300 relative w-full rounded-full\">\n                    <div\n                      className=\"h-[4px] bg-[#E6A219] absolute top-[-1px] rounded-full transition-all duration-500\"\n                      style={{\n                        width: `${100 / selectedProduct.additionalImages.length}%`,\n                        marginLeft: `${(activeImageIndex / selectedProduct.additionalImages.length) * 100}%`,\n                      }}\n                    />\n                  </div>\n \n                  {/* Manual thumbnail select strip */}\n                  <div className=\"flex gap-2.5 justify-center mt-3\">\n                    {selectedProduct.additionalImages.map((img, i) => (\n                      <button\n                        key={i}\n                        onClick={() => setActiveImageIndex(i)}\n                        className={`size-12 rounded-sm overflow-hidden border transition-all ${\n                          activeImageIndex === i ? \"border-[#E6A219]\" : \"border-transparent opacity-60 hover:opacity-100\"\n                        }`}\n                      >\n                        <img\n                          alt=\"Thumbnail preview\"\n                          className=\"w-full h-full object-cover grayscale\"\n                          src={img}\n                          referrerPolicy=\"no-referrer\"\n                        />\n                      </button>\n                    ))}\n                  </div>\n                </div>\n              )}\n            </section>\n \n            {/* Product description & Interactive Panel */}\n            <section className=\"px-6 py-8\">\n              <div className=\"flex justify-between items-start gap-4 mb-6\">\n                <h2 className=\"text-2xl font-black uppercase tracking-tight leading-none text-[#050505] w-2/3\">\n                  {selectedProduct.name}\n                </h2>\n                <p className=\"text-xl font-bold text-[#E6A219] font-display whitespace-nowrap\">\n                  {selectedProduct.price} \342\202\254\n                </p>\n              </div>\n \n              <p className=\"text-xs md:text-sm leading-relaxed text-justify mb-8 tracking-wide font-light text-[#050505]/95\">\n                {selectedProduct.description}\n              </p>\n \n              {/* Size Selector */}\n              {selectedProduct.sizes && (\n                <div className=\"mb-10\">\n                  <div className=\"flex justify-between items-end mb-4\">\n                    <span className=\"text-[10px] font-bold uppercase tracking-widest text-[#737373]\">\n                      TAILLE DISPONIBLE\n                    </span>\n                    <button\n                      onClick={() => alert(\"Consultez notre guide de patronage unique.\")}\n                      className=\"text-[10px] font-bold uppercase tracking-wider underline underline-offset-4 decoration-black/20 hover:decoration-black\"\n                    >\n                      GUIDE DES TAILLES\n                    </button>\n                  </div>\n                  <div className=\"flex gap-3\">\n                    {selectedProduct.sizes.map((sz) => {\n                      const isOutOfStock = sz === \"40\"; // Out of stock on screen 1 is \"40\"\n                      return (\n                        <button\n                          key={sz}\n                          id={`size-btn-${sz}`}\n                          disabled={isOutOfStock}\n                          onClick={() => setSelectedSize(sz)}\n                          className={`size-11 border rounded-sm flex items-center justify-center text-xs font-bold transition-all relative overflow-hidden active:scale-95 ${\n                            isOutOfStock\n                              ? \"text-[#737373]/40 border-neutral-200 cursor-not-allowed bg-neutral-100\"\n                              : selectedSize === sz\n                              ? \"bg-[#050505] text-white border-[#050505]\"\n                              : \"bg-transparent text-[#050505] border-[#050505] hover:bg-black/5\"\n                          }`}\n                        >\n                          {sz}\n                          {isOutOfStock && (\n                            <div className=\"absolute inset-0 w-full h-[1px] bg-[#737373]/30 top-1/2 -translate-y-1/2 rotate-45\" />\n                          )}\n                        </button>\n                      );\n                    })}\n                  </div>\n                </div>\n              )}\n \n              {/* Accordions */}\n              <div className=\"border-t border-[#050505] divide-y divide-[#050505]/10\">\n                {/* COMPOSITION Accordion */}\n                <div className=\"py-4\">\n                  <button\n                    onClick={() => toggleAccordion(\"composition\")}\n                    className=\"w-full flex justify-between items-center text-xs font-bold uppercase tracking-wider text-[#050505] uppercase\"\n                  >\n                    <span>COMPOSITION</span>\n                    <Plus className={`w-4 h-4 text-[#737373] transform transition-transform duration-300 ${openAccordions.composition ? \"rotate-45 text-[#050505]\" : \"\"}`} />\n                  </button>\n                  {openAccordions.composition && (\n                    <div className=\"mt-3 text-xs md:text-sm text-[#737373] leading-relaxed font-light whitespace-pre-line animate-fade-in\">\n                      {selectedProduct.composition || \"Ext\303\251rieur : 85% Laine fine de m\303\251rinos recycl\303\251e, 15% cachemire de soutien.\\nDoublure : 100% Satin de viscose fluide.\"}\n                    </div>\n                  )}\n                </div>\n \n                {/* ENTRETIEN Accordion */}\n                <div className=\"py-4\">\n                  <button\n                    onClick={() => toggleAccordion(\"entretien\")}\n                    className=\"w-full flex justify-between items-center text-xs font-bold uppercase tracking-wider text-[#050505] uppercase\"\n                  >\n                    <span>ENTRETIEN</span>\n                    <Plus className={`w-4 h-4 text-[#737373] transform transition-transform duration-300 ${openAccordions.entretien ? \"rotate-45 text-[#050505]\" : \"\"}`} />\n                  </button>\n                  {openAccordions.entretien && (\n                    <div className=\"mt-3 text-xs md:text-sm text-[#737373] leading-relaxed font-light whitespace-pre-line animate-fade-in\">\n                      {selectedProduct.entretien || \"Nettoyage \303\240 sec sp\303\251cialis\303\251 \303\240 basse temp\303\251rature. Repassage doux sur l\'envers.\"}\n                    </div>\n                  )}\n                </div>\n \n                {/* LIVRAISON & RETOURS Accordion */}\n                <div className=\"py-4\">\n                  <button\n                    onClick={() => toggleAccordion(\"livraison\")}\n                    className=\"w-full flex justify-between items-center text-xs font-bold uppercase tracking-wider text-[#050505] uppercase\"\n                  >\n                    <span>LIVRAISON & RETOURS</span>\n                    <Plus className={`w-4 h-4 text-[#737373] transform transition-transform duration-300 ${openAccordions.livraison ? \"rotate-45 text-[#050505]\" : \"\"}`} />\n                  </button>\n                  {openAccordions.livraison && (\n                    <div className=\"mt-3 text-xs md:text-sm text-[#737373] leading-relaxed font-light whitespace-pre-line animate-fade-in\">\n                      {selectedProduct.livraison || \"Livraison express offerte en emballage soign\303\251 \303\251co-responsable. Retours sans frais sous 14 jours.\"}\n                    </div>\n                  )}\n                </div>\n              </div>\n            </section>\n \n            {/* Fixed Bottom CTA bar */}\n            <div className=\"fixed bottom-0 left-0 w-full p-4 bg-[#f8f7f6]/95 backdrop-blur-sm border-t border-[#050505] z-30 h-20 flex items-center justify-center\">\n              <button\n                id=\"add-to-cart-detail-btn\"\n                onClick={() => handleAddWithFeedback(selectedProduct)}\n                className=\"w-full h-12 bg-[#050505] text-[#f8f7f6] rounded-sm font-bold text-xs uppercase tracking-[0.2em] hover:bg-[#E6A219] hover:text-[#050505] transition-all duration-300 flex items-center justify-center gap-2\"\n              >\n                <span id=\"add-btn-text\">AJOUTER AU PANIER</span>\n              </button>\n            </div>\n          </div>\n        )\n      )}\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"w-full bg-transparent min-h-screen text-slate-300\">\n      {viewState === \"grid\" ? (\n        /* --- HIGH DESIGN GRID CATALOG (Screen 6) --- */\n        <div className=\"w-full\">\n          {/* Subheader and Filters Menu */}\n          <div className=\"border-b border-white/10 flex justify-between items-center px-6 py-4 bg-black/10 backdrop-blur-md\">\n            <button\n              id=\"filtref-btn\"\n              onClick={() => setSelectedFilter(\"ALL\")}\n              className=\"text-xs font-bold uppercase tracking-wider flex items-center gap-1.5 border-b border-transparent hover:text-blue-400 hover:border-blue-400 transition-all text-slate-300\"\n            >\n              FILTRES + {selectedFilter !== \"ALL\" && `(${selectedFilter})`}\n            </button>\n            <span className=\"text-xs uppercase tracking-[0.2em] font-mono text-slate-400\">\n              HAUTE COUTURE\n            </span>\n            <button\n              id=\"trier-btn\"\n              className=\"text-xs font-bold uppercase tracking-wider hover:text-indigo-400 transition-colors text-slate-300\"\n            >\n              TRIER\n            </button>\n          </div>\n\n          {/* Sticking Filter Chips */}\n          <div className=\"flex gap-2 px-6 py-4 overflow-x-auto hide-scrollbar bg-black/5 border-b border-white/5\">\n            {coutureFilters.map((flt) => (\n              <button\n                key={flt}\n                onClick={() => setSelectedFilter(flt)}\n                className={`px-4 py-2 rounded-sm text-[10px] font-bold tracking-widest uppercase transition-all duration-300 border ${\n                  selectedFilter === flt\n                    ? \"bg-blue-600 text-white border-blue-500 shadow-[0_0_12px_rgba(59,130,246,0.4)]\"\n                    : \"bg-white/5 text-slate-400 border-white/5 hover:border-white/20 hover:text-white\"\n                }`}\n              >\n                {flt === \"ALL\" ? \"TOUT VOIR\" : flt}\n              </button>\n            ))}\n          </div>\n\n          {/* Staggered Asymmetric Grid Layout */}\n          <main className=\"max-w-4xl mx-auto px-4 py-8 md:py-12\">\n            <div className=\"grid grid-cols-2 gap-x-4 md:gap-x-8 gap-y-12\">\n              {/* Product cards rendering */}\n              {filteredProducts.map((prod, index) => {\n                const isRightColStaggered = index % 2 === 1;\n                return (\n                  <article\n                    key={prod.id}\n                    onClick={() => handleProductClick(prod)}\n                    className={`flex flex-col group cursor-pointer transition-transform duration-500 hover:-translate-y-1 ${\n                      isRightColStaggered ? \"translate-y-6 md:translate-y-12\" : \"\"\n                    }`}\n                  >\n                    {/* Image Layer */}\n                    <div className=\"relative aspect-[3/4] bg-slate-950 overflow-hidden rounded-md mb-4 border border-white/10 shadow-lg\">\n                      <img\n                        alt={prod.name}\n                        className=\"w-full h-full object-cover grayscale contrast-110 transform transition-transform duration-1000 group-hover:grayscale-0 group-hover:scale-105\"\n                        src={prod.imageUrl}\n                        referrerPolicy=\"no-referrer\"\n                      />\n                      <div className=\"absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300\" />\n                    </div>\n\n                    {/* Meta details */}\n                    <div className=\"flex justify-between items-start gap-2 px-1\">\n                      <div>\n                        <h3 className=\"text-xs md:text-sm font-semibold tracking-wider leading-tight text-white group-hover:text-blue-400 transition-colors uppercase\">\n                          {prod.name}\n                        </h3>\n                        <p className=\"text-[10px] text-slate-500 uppercase mt-0.5 tracking-widest font-mono\">\n                          {prod.category}\n                        </p>\n                      </div>\n                      <span className=\"text-xs md:text-sm font-semibold text-blue-400 shrink-0 font-mono\">\n                        {prod.price} \342\202\254\n                      </span>\n                    </div>\n                  </article>\n                );\n              })}\n            </div>\n\n            {/* Pagination Button */}\n            <div className=\"w-full flex justify-center mt-16 md:mt-24 mb-12\">\n              <button\n                id=\"couture-load-more\"\n                onClick={() => alert(\"La collection compl\303\250te est en ligne. De nouvelles archives arrivent bient\303\264t.\")}\n                className=\"px-8 py-4 border border-white/10 bg-white/5 text-white text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-black transition-all duration-300 rounded-sm active:scale-95 cursor-pointer\"\n              >\n                CHARGER LA SUITE\n              </button>\n            </div>\n          </main>\n        </div>\n      ) : (\n        /* --- PREMIUM OVERSZIED DETAIL PRODUCT VIEW (Screen 1) --- */\n        selectedProduct && (\n          <div className=\"w-full max-w-lg mx-auto pb-32\">\n            {/* Minimal Sub-header */}\n            <div className=\"flex items-center justify-between p-4 bg-transparent border-b border-white/5\">\n              <button\n                onClick={() => setViewState(\"grid\")}\n                className=\"size-8 flex items-center justify-center rounded-full bg-white/5 border border-white/10 hover:bg-white/10 transition-colors\"\n                title=\"Retour au catalogue\"\n              >\n                <ArrowLeft className=\"w-4 h-4 text-white\" />\n              </button>\n              <span className=\"text-xs font-bold uppercase tracking-widest font-mono text-slate-400\">\n                {selectedProduct.category}\n              </span>\n              <span className=\"w-8\"></span>\n            </div>\n\n            {/* Oversized Gallery Carousel */}\n            <section className=\"relative w-full overflow-hidden bg-slate-950\">\n              {/* Main Carousel Screen */}\n              <div className=\"w-full aspect-[4/5] relative\">\n                <img\n                  alt={selectedProduct.name}\n                  className=\"w-full h-full object-cover grayscale contrast-110 transition-all duration-700 hover:grayscale-0\"\n                  src={\n                    selectedProduct.additionalImages\n                      ? selectedProduct.additionalImages[activeImageIndex]\n                      : selectedProduct.imageUrl\n                  }\n                  referrerPolicy=\"no-referrer\"\n                />\n              </div>\n\n              {/* Progress Slider Dots */}\n              {selectedProduct.additionalImages && selectedProduct.additionalImages.length > 1 && (\n                <div className=\"w-full px-6 mt-3\">\n                  <div className=\"h-[2px] bg-slate-800 relative w-full rounded-full\">\n                    <div\n                      className=\"h-[4px] bg-gradient-to-r from-blue-500 to-fuchsia-500 absolute top-[-1px] rounded-full transition-all duration-500\"\n                      style={{\n                        width: `${100 / selectedProduct.additionalImages.length}%`,\n                        marginLeft: `${(activeImageIndex / selectedProduct.additionalImages.length) * 100}%`,\n                      }}\n                    />\n                  </div>\n\n                  {/* Manual thumbnail select strip */}\n                  <div className=\"flex gap-2.5 justify-center mt-3\">\n                    {selectedProduct.additionalImages.map((img, i) => (\n                      <button\n                        key={i}\n                        onClick={() => setActiveImageIndex(i)}\n                        className={`size-12 rounded-sm overflow-hidden border transition-all ${\n                          activeImageIndex === i ? \"border-blue-500\" : \"border-transparent opacity-60 hover:opacity-100\"\n                        }`}\n                      >\n                        <img\n                          alt=\"Thumbnail preview\"\n                          className=\"w-full h-full object-cover grayscale\"\n                          src={img}\n                          referrerPolicy=\"no-referrer\"\n                        />\n                      </button>\n                    ))}\n                  </div>\n                </div>\n              )}\n            </section>\n\n            {/* Product description & Interactive Panel */}\n            <section className=\"px-6 py-8\">\n              <div className=\"flex justify-between items-start gap-4 mb-6\">\n                <h2 className=\"text-2xl font-bold uppercase tracking-tight leading-none text-white w-2/3\">\n                  {selectedProduct.name}\n                </h2>\n                <p className=\"text-xl font-bold text-fuchsia-400 font-mono whitespace-nowrap\">\n                  {selectedProduct.price} \342\202\254\n                </p>\n              </div>\n\n              <p className=\"text-xs md:text-sm leading-relaxed text-justify mb-8 tracking-wide font-light text-slate-300\">\n                {selectedProduct.description}\n              </p>\n\n              {/* Size Selector */}\n              {selectedProduct.sizes && (\n                <div className=\"mb-10\">\n                  <div className=\"flex justify-between items-end mb-4\">\n                    <span className=\"text-[10px] font-bold uppercase tracking-widest text-slate-400 font-mono\">\n                      TAILLE DISPONIBLE\n                    </span>\n                    <button\n                      onClick={() => alert(\"Consultez notre guide de patronage unique.\")}\n                      className=\"text-[10px] font-bold uppercase tracking-wider underline underline-offset-4 decoration-white/25 hover:decoration-white hover:text-white transition-colors\"\n                    >\n                      GUIDE DES TAILLES\n                    </button>\n                  </div>\n                  <div className=\"flex gap-3\">\n                    {selectedProduct.sizes.map((sz) => {\n                      const isOutOfStock = sz === \"40\"; // Out of stock on screen 1 is \"40\"\n                      return (\n                        <button\n                          key={sz}\n                          id={`size-btn-${sz}`}\n                          disabled={isOutOfStock}\n                          onClick={() => setSelectedSize(sz)}\n                          className={`size-11 border rounded-sm flex items-center justify-center text-xs font-bold transition-all relative overflow-hidden active:scale-95 ${\n                            isOutOfStock\n                              ? \"text-slate-600 border-white/5 cursor-not-allowed bg-black/40 line-through\"\n                              : selectedSize === sz\n                              ? \"bg-blue-600 text-white border-blue-500 shadow-[0_0_12px_rgba(59,130,246,0.5)]\"\n                              : \"bg-transparent text-slate-200 border-white/10 hover:bg-white/5 hover:border-white/30\"\n                          }`}\n                        >\n                          {sz}\n                        </button>\n                      );\n                    })}\n                  </div>\n                </div>\n              )}\n\n              {/* Accordions */}\n              <div className=\"border-t border-white/10 divide-y divide-white/5\">\n                {/* COMPOSITION Accordion */}\n                <div className=\"py-4\">\n                  <button\n                    onClick={() => toggleAccordion(\"composition\")}\n                    className=\"w-full flex justify-between items-center text-xs font-bold uppercase tracking-wider text-slate-200\"\n                  >\n                    <span>COMPOSITION</span>\n                    <Plus className={`w-4 h-4 text-slate-400 transform transition-transform duration-300 ${openAccordions.composition ? \"rotate-45 text-white\" : \"\"}`} />\n                  </button>\n                  {openAccordions.composition && (\n                    <div className=\"mt-3 text-xs md:text-sm text-slate-400 leading-relaxed font-light whitespace-pre-line animate-fade-in\">\n                      {selectedProduct.composition || \"Ext\303\251rieur : 85% Laine fine de m\303\251rinos recycl\303\251e, 15% cachemire de soutien.\\nDoublure : 100% Satin de viscose fluide.\"}\n                    </div>\n                  )}\n                </div>\n\n                {/* ENTRETIEN Accordion */}\n                <div className=\"py-4\">\n                  <button\n                    onClick={() => toggleAccordion(\"entretien\")}\n                    className=\"w-full flex justify-between items-center text-xs font-bold uppercase tracking-wider text-slate-200\"\n                  >\n                    <span>ENTRETIEN</span>\n                    <Plus className={`w-4 h-4 text-slate-400 transform transition-transform duration-300 ${openAccordions.entretien ? \"rotate-45 text-white\" : \"\"}`} />\n                  </button>\n                  {openAccordions.entretien && (\n                    <div className=\"mt-3 text-xs md:text-sm text-slate-400 leading-relaxed font-light whitespace-pre-line animate-fade-in\">\n                      {selectedProduct.entretien || \"Nettoyage \303\240 sec sp\303\251cialis\303\251 \303\240 basse temp\303\251rature. Repassage doux sur l\'envers.\"}\n                    </div>\n                  )}\n                </div>\n\n                {/* LIVRAISON & RETOURS Accordion */}\n                <div className=\"py-4\">\n                  <button\n                    onClick={() => toggleAccordion(\"livraison\")}\n                    className=\"w-full flex justify-between items-center text-xs font-bold uppercase tracking-wider text-slate-200\"\n                  >\n                    <span>LIVRAISON & RETOURS</span>\n                    <Plus className={`w-4 h-4 text-slate-400 transform transition-transform duration-300 ${openAccordions.livraison ? \"rotate-45 text-white\" : \"\"}`} />\n                  </button>\n                  {openAccordions.livraison && (\n                    <div className=\"mt-3 text-xs md:text-sm text-slate-400 leading-relaxed font-light whitespace-pre-line animate-fade-in\">\n                      {selectedProduct.livraison || \"Livraison express offerte en emballage soign\303\251 \303\251co-responsable. Retours sans frais sous 14 jours.\"}\n                    </div>\n                  )}\n                </div>\n              </div>\n            </section>\n\n            {/* Fixed Bottom CTA bar */}\n            <div className=\"fixed bottom-0 left-0 w-full p-4 bg-black/80 backdrop-blur-md border-t border-white/10 z-30 h-20 flex items-center justify-center\">\n              <button\n                id=\"add-to-cart-detail-btn\"\n                onClick={() => handleAddWithFeedback(selectedProduct)}\n                className=\"w-full h-12 bg-gradient-to-r from-blue-600 to-fuchsia-600 text-white rounded-sm font-bold text-xs uppercase tracking-[0.2em] hover:brightness-110 active:scale-95 transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer shadow-lg shadow-blue-500/20\"\n              >\n                <span id=\"add-btn-text\">AJOUTER AU PANIER</span>\n              </button>\n            </div>\n          </div>\n        )\n      )}\n    </div>\n  );"
