      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { CollectionId } from \"../types\";\n\ninterface OrigineEntryProps {\n  onSelectCollection: (collectionId: CollectionId) => void;\n}\n\nexport default function OrigineEntry({ onSelectCollection }: OrigineEntryProps) {\n  return (\n    <div className=\"h-screen w-full flex flex-col overflow-hidden bg-[#f8f7f6] select-none font-sans\">\n      {/* Split screen content structure */}\n      <div className=\"flex-1 flex flex-col relative w-full h-[calc(100vh-40px-48px)]\">\n        {/* Women\'s Couture / Haute Line Block (Top 50%) - Screen 4 styled */}\n        <div\n          onClick={() => onSelectCollection(\"couture\")}\n          className=\"group relative h-1/2 w-full block overflow-hidden border-b border-[#050505] cursor-pointer\"\n        >\n          {/* Cover image backdrop */}\n          <div\n            className=\"absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105\"\n            style={{\n              backgroundImage: `url(\'https://lh3.googleusercontent.com/aida-public/AB6AXuBEHnnYyisBwmj9RB6-VnPibFQ79b0Js4t-NpzmRLIOcC-iedNgFifm81BAbG2_gU4T36OhyUuFfOD6Lgstc4xrTO9jQQLnaaklQVlFfIQ1VCwU-s4HCOHacez7HdshXXFn8XkLeIx_nb3Fk86SikbYGvEfBkgFxZedPtVbwCmBFDmMAqZYLbtkJiiJfR3eO-ZgabiJuQqarbwkXV1cNPNxdX900M1ldEXsqL0AAv_2OV0jM4P4rAwniMhKNCUADejMF-kikKov_U-J\')`,\n            }}\n          />\n          {/* Subtle gradient overlay */}\n          <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-black/10 transition-colors\" />\n\n          {/* Texts overlay */}\n          <div className=\"absolute inset-0 p-6 flex flex-col justify-end items-start z-10\">\n            <h2 className=\"font-display font-extrabold uppercase text-white text-3xl md:text-4xl tracking-tight leading-none mb-3\">\n              LA LIGNE<br />FEMME\n            </h2>\n            <div className=\"self-end mt-auto transform group-hover:translate-x-1.5 transition-transform duration-300\">\n              <span className=\"inline-flex items-center justify-center px-6 py-2.5 border border-white text-white font-semibold text-xs uppercase tracking-[0.15em] bg-transparent backdrop-blur-sm group-hover:bg-white group-hover:text-black transition-all\">\n                D\303\211COUVRIR\n              </span>\n            </div>\n          </div>\n        </div>\n\n        {/* L\'\303\211crin Fine Jewelry Block (Bottom 50%) - Screen 4 styled */}\n        <div\n          onClick={() => onSelectCollection(\"ecrin\")}\n          className=\"group relative h-1/2 w-full block overflow-hidden bg-[#f8f7f6] cursor-pointer\"\n        >\n          {/* Cover image backdrop with offset container */}\n          <div className=\"absolute inset-4 rounded-sm overflow-hidden bg-[#EBE9E4]\">\n            <div\n              className=\"absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-105 opacity-90 grayscale contrast-125 saturate-50\"\n              style={{\n                backgroundImage: `url(\'https://lh3.googleusercontent.com/aida-public/AB6AXuDywck-XM7fe1EwErRv_67DkPxdyZzcWDoueVO-PTKNzbalSjCjwK8WU2s85Pwcbek1Bm_NFluKUeDzhwbeqVtsay7AfpkneuoYBSZUkZWmBI_86qyTu0FNvofwSWyOnz7awD7ObLx2j4wn18iwpCLfsFxJEj-1RyrUGhmiYPp--4f7el_ecW07XXc-5kBWzGAupNFZ7oSX03ZyUkNnwZTdvZA5FCsWreBu1024-PtHdkm1iAneBiKIN8-fgh4ctaTUKNdwkCSv-ZGL\')`,\n              }}\n            />\n            {/* Subtle Overlay */}\n            <div className=\"absolute inset-0 bg-black/15 group-hover:bg-black/25 transition-colors\" />\n\n            {/* Texts */}\n            <div className=\"absolute inset-0 p-4 flex flex-col justify-between z-10\">\n              <h2 className=\"font-display font-extrabold uppercase text-[#E6A219] text-xl md:text-2xl tracking-tighter leading-none max-w-[65%] drop-shadow-md\">\n                L\'\303\211CRIN DE SOIE\n              </h2>\n\n              <div className=\"self-end mt-auto transform group-hover:translate-x-1.5 transition-transform duration-300\">\n                <span className=\"inline-flex items-center justify-center px-6 py-2 border border-[#E6A219] text-[#E6A219] font-bold text-[10px] uppercase tracking-[0.15em] bg-black/5 backdrop-blur-sm group-hover:bg-[#E6A219] group-hover:text-black transition-all\">\n                  ENTRER\n                </span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Endless Scroll Marquee element - bottom (Screen 4 style) */}\n      <footer className=\"h-10 shrink-0 bg-[#E6A219] w-full overflow-hidden flex items-center border-t border-[#050505] relative z-20\">\n        <div className=\"flex whitespace-nowrap animate-marquee font-display font-bold text-[#f8f7f6] text-xs uppercase tracking-[0.2em] relative py-1\">\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          {/* Double content segment for continuous illusion */}\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n          <span className=\"px-6\">NOUVELLE COLLECTION // ARCHITECTURE DE L\'\303\211L\303\211GANCE //</span>\n        </div>\n      </footer>\n    </div>\n  );\n}\n"
